# MultiCloud MLOps - Environment Variables
# Copy to .env and fill in YOUR values.
# NEVER commit .env to git (already in .gitignore).

# ─── AWS ────────────────────────────────────────────────
# IAM user with S3/SQS/DynamoDB permissions (programmatic access)
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1

# Auto-populated by setup.py (or fill manually):
# S3_BUCKET_NAME=guardian-videos-12345678
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/guardian-video-processing
# SQS_GPU_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/guardian-gpu-processing
DYNAMODB_VIDEOS_TABLE=guardian-videos
DYNAMODB_EVENTS_TABLE=guardian-events

# ─── Azure ──────────────────────────────────────────────
# az account list --output table  →  copy Subscription Id
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=guardian-ai-prod
AZURE_LOCATION=eastus
# Leave blank to auto-generate (e.g. guardianacr58206), or set explicitly:
AZURE_ACR_NAME=
AZURE_AKS_CLUSTER=guardian-ai-aks

# ─── Azure DevOps ───────────────────────────────────────
AZDO_ORG_NAME=guardian-ai-org
AZDO_PROJECT_NAME=guardian-ai-mlops
# Generate at: https://dev.azure.com → User Settings → Personal Access Tokens
# Required scopes: Agent Pools (R&M), Build (R&E), Code (R),
#                  Project and Team (R&W), Service Connections (R,Q,M),
#                  Variable Groups (R,C,M)
AZDO_PAT_TOKEN=your_pat_token_here

# ─── Azure ML ───────────────────────────────────────────
AZURE_ML_WORKSPACE=guardian-ai-ml-workspace-prod
AZURE_ML_COMPUTE_CLUSTER=cpu-training-cluster

# ─── Azure OpenAI (optional) ────────────────────────────
AZURE_OPENAI_ENABLED=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ─── Application ────────────────────────────────────────
AUTO_APPROVE_THRESHOLD=0.2
AUTO_REJECT_THRESHOLD=0.8
LOG_LEVEL=INFO

# ─── Azure ML Endpoint URIs (auto-populated by setup.py stage: ml) ───
# NSFW_MODEL_ENDPOINT=https://nsfw-detector-endpoint.eastus.inference.ml.azure.com/score
# VIOLENCE_MODEL_ENDPOINT=https://violence-detector-endpoint.eastus.inference.ml.azure.com/score
# MODEL_ENDPOINT_KEY=your_endpoint_key

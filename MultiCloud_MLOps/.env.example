# ============================================================
# Guardian AI — MultiCloud MLOps Environment Variables
# ============================================================
# SETUP INSTRUCTIONS:
#   cp .env.example .env
#   Fill in every value marked <YOUR_VALUE>
#   NEVER commit .env to git (it's in .gitignore)
# ============================================================

# ─── AWS ────────────────────────────────────────────────────
# IAM user with S3/SQS/DynamoDB permissions (programmatic access)
# Create at: AWS Console → IAM → Users → marcos-mlops → Security credentials
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_ACCESS_KEY>
AWS_REGION=us-east-1

# S3 Bucket Name Override (IMPORTANT — read below)
# AWS enforces a cooldown period after bucket deletion before the same name
# can be reused. If you get "OperationAborted" on S3 creation, set a custom
# bucket name here to bypass the cooldown:
# S3_BUCKET_OVERRIDE=guardian-videos-yourname-dev
# Leave commented out to auto-generate: guardian-videos-<account-id-prefix>

# Auto-populated by setup.py --stage aws (do not edit manually):
# S3_BUCKET_NAME=guardian-videos-xxxxxxxx
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account-id>/guardian-video-processing
# SQS_GPU_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account-id>/guardian-gpu-processing
# DYNAMODB_VIDEOS_TABLE=guardian-videos
# DYNAMODB_EVENTS_TABLE=guardian-events

# ─── Azure ──────────────────────────────────────────────────
# Get subscription ID: az account show --query id --output tsv
AZURE_SUBSCRIPTION_ID=<YOUR_SUBSCRIPTION_ID>
AZURE_RESOURCE_GROUP=guardian-ai-prod
AZURE_LOCATION=eastus

# ACR name is auto-generated and persisted here by setup.py --stage azure
# Format: guardianacr<5-digit-random>
# Leave blank — setup.py will populate it automatically:
AZURE_ACR_NAME=

AZURE_AKS_CLUSTER=guardian-ai-aks

# ─── Azure Service Principal (for DevOps service connections) ─
# Create with: az ad sp create-for-rbac --name guardian-ai-sp \
#              --role Contributor \
#              --scopes /subscriptions/<YOUR_SUBSCRIPTION_ID>
# Then fill in the values from the JSON output:
AZURE_SP_APP_ID=<YOUR_SP_APP_ID>
AZURE_SP_SECRET=<YOUR_SP_SECRET>
AZURE_TENANT_ID=<YOUR_TENANT_ID>
AZURE_SUBSCRIPTION_NAME=Azure subscription 1

# ─── Azure DevOps ───────────────────────────────────────────
# Your Azure DevOps org name (the part after dev.azure.com/)
# Example: if URL is dev.azure.com/maofilho → AZDO_ORG_NAME=maofilho
AZDO_ORG_NAME=<YOUR_AZDO_ORG_NAME>
AZDO_PROJECT_NAME=guardian-ai-mlops

# Generate PAT at: https://dev.azure.com → Profile → Personal access tokens
# Required scopes: Agent Pools (R&M), Build (R&E), Code (R),
#   Project and Team (R&W&C), Service Connections (R,Q,M),
#   Variable Groups (R,C,M)
AZDO_PAT_TOKEN=<YOUR_PAT_TOKEN>

# ─── Azure ML ───────────────────────────────────────────────
AZURE_ML_WORKSPACE=guardian-ai-ml-workspace-prod
AZURE_ML_COMPUTE_CLUSTER=cpu-training-cluster

# ─── Azure OpenAI (optional — set AZURE_OPENAI_ENABLED=true to activate) ─
AZURE_OPENAI_ENABLED=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ─── Application ────────────────────────────────────────────
# Videos with risk score below this threshold are auto-approved
AUTO_APPROVE_THRESHOLD=0.2
# Videos with risk score above this threshold are auto-rejected
AUTO_REJECT_THRESHOLD=0.8
LOG_LEVEL=INFO

# ─── Azure ML Endpoints (auto-populated by setup.py --stage ml) ─
# These are filled in automatically after model deployment:
# NSFW_MODEL_ENDPOINT=https://nsfw-detector-endpoint.eastus.inference.ml.azure.com/score
# VIOLENCE_MODEL_ENDPOINT=https://violence-detector-endpoint.eastus.inference.ml.azure.com/score
# MODEL_ENDPOINT_KEY=<endpoint_key>
